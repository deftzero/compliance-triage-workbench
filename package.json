{
  "name": "compliance-triage-workbench",
  "private": true,
  "scripts": {
    "setup": "./scripts/setup.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "typecheck": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:e2e:headed": "pnpm --filter admin test:e2e:headed",
    "test:e2e:ui": "pnpm --filter admin test:e2e:ui"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22"
  }
}
