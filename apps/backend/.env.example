# Copy to .env and adjust. Never commit .env.

NODE_ENV=development
PORT=3001

# Any string of 16+ chars. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1h

# Where the admin app is served from, for CORS.
CORS_ORIGIN=http://localhost:5173

# memory  -> in-process store, no infra required (default)
# database -> Postgres via Drizzle; DATABASE_URL becomes required
PERSISTENCE=memory
# DATABASE_URL=postgres://user:password@localhost:5432/compliance_triage
