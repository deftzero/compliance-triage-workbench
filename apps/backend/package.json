{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@pothos/core": "^4.13.1",
    "@repo/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "graphql": "^16.14.2",
    "graphql-yoga": "^5.21.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.20.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "test": "vitest run"
  }
}
