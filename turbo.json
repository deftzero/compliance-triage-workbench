{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": [
        "PORT",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "PERSISTENCE",
        "DATABASE_URL",
        "CORS_ORIGIN",
        "VITE_API_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "test:e2e": {
      "cache": false,
      "env": ["PORT", "JWT_SECRET", "CORS_ORIGIN", "VITE_API_URL", "CI"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "PORT",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "PERSISTENCE",
        "DATABASE_URL",
        "CORS_ORIGIN",
        "VITE_API_URL"
      ]
    }
  }
}
